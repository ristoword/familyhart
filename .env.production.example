# Frontend production (Railway static/public host)
# Copia in .env.production per build locale prod, oppure imposta sul servizio frontend Railway.

# URL pubblico frontend Family Hart (informativo/documentale)
VITE_PUBLIC_APP_URL=https://family-hart.up.railway.app

# URL backend Family Hart (API HTTP)
VITE_API_URL=https://family-hart-api.up.railway.app

# URL socket (di norma uguale all'API host)
VITE_SOCKET_URL=https://family-hart-api.up.railway.app

# WebRTC / TURN
VITE_STUN_URL=stun:stun.l.google.com:19302
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# Vetrina esterna (Gestione Semplificata)
VITE_GESTIONE_SEMPLIFICATA_URL=https://gestione-semplificata.example.com
