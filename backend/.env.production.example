# Backend production (Railway service)
# Su Railway imposta queste variabili nella dashboard del servizio backend.

PORT=3001
NODE_ENV=production

# Frontend Family Hart (produzione)
CLIENT_URL=https://family-hart.up.railway.app

# CORS: includi frontend Family Hart + eventuale dominio vetrina Gestione Semplificata
CORS_ORIGINS=https://family-hart.up.railway.app,https://gestione-semplificata.example.com

JWT_SECRET=sostituisci-con-segreto-forte
JWT_EXPIRES_IN=7d

# Railway volume mount path consigliato (adatta al tuo mount reale)
DATABASE_PATH=/data/familyhart.db

JSON_LIMIT=256kb
AUTH_RATE_WINDOW_MS=60000
AUTH_RATE_MAX=15
API_RATE_WINDOW_MS=60000
API_RATE_MAX=300
ACTIVATE_RATE_WINDOW_MS=3600000
ACTIVATE_RATE_MAX=20
LOCATION_SOCKET_MIN_INTERVAL_MS=2500

# Beta privata
BETA_ACCESS_REQUIRED=true
BETA_EMAIL_ALLOWLIST=

# Web Push (richiede HTTPS)
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:prod@familyhart.local
