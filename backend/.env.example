# Family Hart Backend - Variabili ambiente
# Copia in .env e adatta

PORT=3001
NODE_ENV=development
# In locale il server ascolta su 127.0.0.1 (vedi log http://localhost:PORT).
# Da telefono sulla stessa LAN o Docker: HOST=0.0.0.0
# HOST=
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# --- Railway (servizio BACKEND) ---
# Non impostare PORT a mano se Railway lo fornisce già (numero intero).
# NODE_ENV=production
# HOST lasciato vuoto → ascolto su 0.0.0.0
# CLIENT_URL=https://URL-PUBBLICO-FRONTEND.up.railway.app
# CORS_ORIGINS=https://URL-PUBBLICO-FRONTEND.up.railway.app
# DATABASE_PATH=/data/familyhart.db   (con volume montato su /data)
# JWT_SECRET=<stringa lunga casuale>
# PUSH_VAPID_* se usi notifiche push

# Throttle minimo tra emit posizione via socket (ms)
LOCATION_SOCKET_MIN_INTERVAL_MS=2500

# JWT
JWT_SECRET=cambiami-in-produzione-scegli-stringa-sicura
JWT_EXPIRES_IN=7d

# Database SQLite (path relativo a backend/)
DATABASE_PATH=./data/familyhart.db

# Sicurezza / limiti
JSON_LIMIT=256kb
AUTH_RATE_WINDOW_MS=60000
AUTH_RATE_MAX=15
API_RATE_WINDOW_MS=60000
API_RATE_MAX=300
ACTIVATE_RATE_WINDOW_MS=3600000
ACTIVATE_RATE_MAX=20

# Beta privata (opzionale)
BETA_ACCESS_REQUIRED=false
BETA_EMAIL_ALLOWLIST=

# Web Push (VAPID)
# Genera con: npx web-push generate-vapid-keys
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:dev@familyhart.local
