# Backend staging — copia in backend/.env.staging oppure imposta le stesse variabili sul provider (Render/Railway)
# Avvio locale staging: npm run start:staging

PORT=3001
NODE_ENV=staging
CLIENT_URL=https://family-hart-staging.example.com
CORS_ORIGINS=https://family-hart-staging.example.com,https://www.family-hart-staging.example.com

JWT_SECRET=sostituisci-con-segreto-lungo-unico-staging
JWT_EXPIRES_IN=7d

# Database dedicato staging (su Render: path su disco persistente)
DATABASE_PATH=./data/familyhart-staging.db

JSON_LIMIT=256kb
AUTH_RATE_WINDOW_MS=60000
AUTH_RATE_MAX=15
API_RATE_WINDOW_MS=60000
API_RATE_MAX=300
ACTIVATE_RATE_WINDOW_MS=3600000
ACTIVATE_RATE_MAX=20

LOCATION_SOCKET_MIN_INTERVAL_MS=2500

# Beta privata
BETA_ACCESS_REQUIRED=true
BETA_EMAIL_ALLOWLIST=

PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:staging@familyhart.local
