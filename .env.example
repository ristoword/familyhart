# --- Locale (npm run dev su :5173) ---
# Lascia vuoto: fetch /api e socket /socket.io passano dal proxy Vite → backend :3001
VITE_API_URL=
VITE_SOCKET_URL=
#
# Alternativa (chiamata diretta al backend, senza proxy):
# VITE_API_URL=http://localhost:3001
# VITE_SOCKET_URL=http://localhost:3001

# --- Railway (variabili di build del servizio FRONTEND) ---
# Sostituisci con l’URL pubblico HTTPS del servizio BACKEND (stesso valore per entrambe):
# VITE_API_URL=https://TUO-BACKEND.up.railway.app
# VITE_SOCKET_URL=https://TUO-BACKEND.up.railway.app

# Staging: copia questo file in .env.staging e imposta URL API pubblici, poi:
# npm run build:staging

# TURN/STUN placeholders (frontend docs/config)
VITE_STUN_URL=stun:stun.l.google.com:19302
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

